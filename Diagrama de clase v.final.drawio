<mxfile host="app.diagrams.net" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/145.0.0.0 Safari/537.36" version="29.6.1">
  <diagram name="Página-1" id="8ulzF4-WvHu2UWD0kzrd">
    <mxGraphModel dx="1042" dy="562" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam classAttributeIconSize 0\npackage \&quot;Logica\&quot; {\n    class GrafoProteinas {\n        - vertices : ListaSimple\n        + obtenerVertice(nombre: String) : Vertice\n        + agregarProteina(nombre: String) : void\n        + eliminarProteina(nombre: String) : void\n        + agregarInteraccion(origen: String, destino: String, peso: double) : void\n        + eliminarInteraccion(origen: String, destino: String) : void\n    }\n\n    class Vertice {\n        - nombre : String\n        - distancia : Double\n        - padre : Vertice\n        - visitado : boolean\n        - adyacentes : ListaSimple\n        + Vertice(nombre: String)\n        + getNombre() : String\n        + getAdyacentes() : ListaSimple\n    }\n\n    class Arista {\n        - destino : Vertice\n        - peso : double\n        + Arista(destino: Vertice, peso: double)\n        + getDestino() : Vertice\n        + getPeso() : double\n    }\n}\n\npackage \&quot;Algoritmos\&quot; {\n    class AlgoritmosGrafo {\n        + dijkstra(grafo: GrafoProteinas, origenNombre: String, destinoNombre: String) : ListaSimple\n        + encontrarHub(grafo: GrafoProteinas) : Vertice\n        + detectarComplejos(grafo: GrafoProteinas) : ListaSimple\n    }\n}\n\npackage \&quot;Persistencia\&quot; {\n    class ManejadorCSV {\n        + cargarGrafoDesdeCSV(rutaArchivo: String, grafo: GrafoProteinas) : void\n        + guardarGrafoEnCSV(rutaArchivo: String, grafo: GrafoProteinas) : void\n    }\n}\n\npackage \&quot;TDA\&quot; {\n    class ListaSimple {\n        - tamanio : int\n        - cabeza : Nodo\n        + insertarAlInicio(dato: Object) : void\n        + insertarAlFinal(dato: Object) : void\n        + tamanio() : int\n        + obtener(i: int) : Object\n    }\n\n    class Cola {\n        + encolar(dato: Object) : void\n        + desencolar() : Object\n        + estaVacia() : boolean\n    }\n\n    class Nodo {\n        - dato : Object\n        - siguiente : Nodo\n    }\n}\n\npackage \&quot;Gui\&quot; {\n    class MainFrame {\n        - grafoLogico : GrafoProteinas\n        - grafoVisual : Graph\n        - viewPanel : ViewPanel\n        - panelGrafo : JPanel\n        + inicializarGrafoVisual(ruta: String) : void\n        + initComponents() : void\n        + actualizarVista() : void\n        + main(args: String[]) : void\n    }\n}\n\n&#39; Relaciones entre clases\nGrafoProteinas \&quot;1\&quot; o-- \&quot;many\&quot; Vertice : contiene &gt;\nVertice \&quot;1\&quot; o-- \&quot;many\&quot; Arista : tiene &gt;\nArista \&quot;1\&quot; --&gt; \&quot;1\&quot; Vertice : apunta a &gt;\n\nGrafoProteinas ..&gt; ListaSimple : usa\nVertice ..&gt; ListaSimple : usa\n\nListaSimple \&quot;1\&quot; *-- \&quot;many\&quot; Nodo : compuesta por &gt;\nCola \&quot;1\&quot; *-- \&quot;many\&quot; Nodo : compuesta por &gt;\n\nMainFrame \&quot;1\&quot; *-- \&quot;1\&quot; GrafoProteinas : maneja &gt;\nAlgoritmosGrafo ..&gt; GrafoProteinas : procesa\nAlgoritmosGrafo ..&gt; Cola : usa\nManejadorCSV ..&gt; GrafoProteinas : lee/escribe\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="sDSscXLlWLUQOhuRU2TK-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1092" width="1687" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
