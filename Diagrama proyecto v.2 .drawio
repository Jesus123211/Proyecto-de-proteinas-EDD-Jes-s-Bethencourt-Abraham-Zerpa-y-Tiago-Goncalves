        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam classAttributeIconSize 0\nscale 1.5\n\npackage \&quot;Logica\&quot; {\n    class GrafoProteinas {\n        - vertices: ListaSimple\n        + agregarProteina(nombre: String): void\n        + agregarInteraccion(origen: String, destino: String, peso: double): void\n        + eliminarProteina(nombre: String): void\n        + eliminarInteraccion(origen: String, destino: String): void\n        + obtenerVertice(nombre: String): Vertice\n    }\n\n    class Vertice {\n        - nombre: String\n        - visitado: boolean\n        - distancia: double\n        - padre: Vertice\n        - adyacentes: ListaSimple\n        + Vertice(nombre: String)\n    }\n\n    class Arista {\n        - destino: Vertice\n        - peso: double\n        + Arista(destino: Vertice, peso: double)\n    }\n}\n\npackage \&quot;TDA\&quot; {\n    class ListaSimple {\n        - cabeza: Nodo\n        - tamanio: int\n        + insertarAlInicio(valor: Object): void\n        + insertarAlFinal(valor: Object): void\n        + obtener(indice: int): Object\n        + tamanio(): int\n    }\n\n    class Cola {\n        - frente: Nodo\n        - fin: Nodo\n        + encolar(valor: Object): void\n        + desencolar(): Object\n        + estaVacia(): boolean\n    }\n\n    class Nodo {\n        - valor: Object\n        - siguiente: Nodo\n    }\n}\n\npackage \&quot;Algoritmos\&quot; {\n    class AlgoritmosGrafo {\n        + dijkstra(grafo: GrafoProteinas, origen: String, destino: String): ListaSimple\n        + encontrarHub(grafo: GrafoProteinas): Vertice\n        + detectarComplejos(grafo: GrafoProteinas): ListaSimple\n    }\n}\n\npackage \&quot;Persistencia\&quot; {\n    class ManejadorCSV {\n        + cargarGrafoDesdeCSV(ruta: String, grafo: GrafoProteinas): void\n        + guardarGrafoEnCSV(ruta: String, grafo: GrafoProteinas): void\n    }\n}\n\npackage \&quot;Gui\&quot; {\n    class MainFrame {\n        - grafoLogico: GrafoProteinas\n        - grafoVisual: Graph\n        - viewPanel: ViewPanel\n        - rutaArchivo: String\n        + inicializarGrafoVisual(): void\n        + initComponents(): void\n    }\n}\n\npackage \&quot;proyectoabrahamzerpa\&quot; {\n    class ProyectoAbrahamZerpa {\n        + main(args: String[]): void\n    }\n}\n\n&#39; Relaciones\nGrafoProteinas \&quot;1\&quot; *-- \&quot;1\&quot; ListaSimple : usa (vértices)\nVertice \&quot;1\&quot; *-- \&quot;1\&quot; ListaSimple : usa (adyacentes)\nListaSimple \&quot;1\&quot; *-- \&quot;*\&quot; Nodo : contiene\nCola \&quot;1\&quot; *-- \&quot;*\&quot; Nodo : contiene\nArista \&quot;*\&quot; --&gt; \&quot;1\&quot; Vertice : apunta a destino\n\nAlgoritmosGrafo ..&gt; GrafoProteinas : procesa\nManejadorCSV ..&gt; GrafoProteinas : lee/escribe\n\nMainFrame \&quot;1\&quot; *-- \&quot;1\&quot; GrafoProteinas : controla\nProyectoAbrahamZerpa ..&gt; MainFrame : inicia interfaz\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="7ojajNXVROADDa1mlv7L-1">
