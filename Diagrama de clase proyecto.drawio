<mxfile host="app.diagrams.net" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/145.0.0.0 Safari/537.36" version="29.6.1">
  <diagram name="Página-1" id="IuCw3pke30zQXEfMEeyX">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam classAttributeIconSize 0\n\npackage Logica {\n    class GrafoProteinas {\n        + vertices : ListaSimple&lt;Vertice&gt;\n        + GrafoProteinas()\n        + agregarProteina(nombre : String)\n        + agregarInteraccion(origen : String, destino : String, peso : double)\n        + obtenerVertice(nombre : String) : Vertice\n        + eliminarProteina(nombre : String)\n        + eliminarInteraccion(origen : String, destino : String)\n        - eliminarInteraccionInterna(v : Vertice, destinoNombre : String)\n    }\n\n    class Vertice {\n        + nombre : String\n        + adyacentes : ListaSimple&lt;Arista&gt;\n        + visitado : boolean\n        + distancia : double\n        + padre : Vertice\n        + Vertice(nombre : String)\n    }\n\n    class Arista {\n        + destino : Vertice\n        + peso : double\n        + Arista(destino : Vertice, peso : double)\n    }\n}\n\npackage TDA {\n    class ListaSimple&lt;T&gt; {\n        - cabeza : Nodo&lt;T&gt;\n        - tamanio : int\n        + ListaSimple()\n        + insertarAlFinal(valor : T)\n        + insertarAlInicio(valor : T)\n        + obtener(indice : int) : T\n        + eliminar(valor : T)\n        + tamanio() : int\n    }\n\n    class Cola&lt;T&gt; {\n        - frente : Nodo&lt;T&gt;\n        - fin : Nodo&lt;T&gt;\n        + encolar(valor : T)\n        + desencolar() : T\n        + estaVacia() : boolean\n    }\n\n    class Nodo&lt;T&gt; {\n        + valor : T\n        + siguiente : Nodo&lt;T&gt;\n        + Nodo(valor : T)\n    }\n}\n\npackage Algoritmos {\n    class AlgoritmosGrafo {\n        + {static} dijkstra(grafo : GrafoProteinas, origenNombre : String, destinoNombre : String) : ListaSimple&lt;Vertice&gt;\n        + {static} encontrarHub(grafo : GrafoProteinas) : Vertice\n        + {static} detectarComplejos(grafo : GrafoProteinas) : ListaSimple&lt;ListaSimple&lt;Vertice&gt;&gt;\n    }\n}\n\npackage Persistencia {\n    class ManejadorCSV {\n        + {static} cargarGrafoDesdeCSV(ruta : String, grafo : GrafoProteinas)\n        + {static} guardarGrafoEnCSV(ruta : String, grafo : GrafoProteinas)\n    }\n}\n\npackage Gui {\n    class MainFrame {\n        - grafoLogico : GrafoProteinas\n        - grafoVisual : Graph\n        - viewPanel : ViewPanel\n        - rutaArchivo : String\n        + MainFrame()\n        - inicializarGrafoVisual()\n        - actualizarVista()\n        + {static} main(args : String[])\n    }\n}\n\n&#39; Relaciones principales\nGrafoProteinas \&quot;1\&quot; *-- \&quot;*\&quot; Vertice : contiene &gt;\nVertice \&quot;1\&quot; *-- \&quot;*\&quot; Arista : adyacentes &gt;\nArista --&gt; \&quot;1\&quot; Vertice : destino &gt;\n\n&#39; Relaciones con TDA\nListaSimple \&quot;1\&quot; *-- \&quot;*\&quot; Nodo : maneja &gt;\nCola \&quot;1\&quot; *-- \&quot;*\&quot; Nodo : maneja &gt;\nGrafoProteinas ..&gt; ListaSimple : usa\nVertice ..&gt; ListaSimple : usa\n\n&#39; Dependencias funcionales\nAlgoritmosGrafo ..&gt; GrafoProteinas : analiza &gt;\nManejadorCSV ..&gt; GrafoProteinas : lee/escribe &gt;\nMainFrame *-- \&quot;1\&quot; GrafoProteinas : gestiona &gt;\nMainFrame ..&gt; ManejadorCSV : usa &gt;\nMainFrame ..&gt; AlgoritmosGrafo : usa &gt;\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="pj0MoEM3IOFJakHPdRC4-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1326" width="1369" x="20" y="170" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
